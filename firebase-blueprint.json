{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the application, either a professor or a parent.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "role": {
          "type": "string",
          "enum": ["professor", "pai", "admin"],
          "description": "The role of the user in the system."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "filhos": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of student names associated with this parent (only applicable for role 'pai')."
        }
      },
      "required": ["uid", "role", "email", "name"]
    },
    "Registro": {
      "title": "Registro",
      "description": "An observation record created by a professor for a student.",
      "type": "object",
      "properties": {
        "dataHora": {
          "type": "timestamp",
          "description": "The date and time the record was created."
        },
        "nomeAluno": {
          "type": "string",
          "description": "The name of the student being observed."
        },
        "habilidadeAlvo": {
          "type": "string",
          "description": "The target skill being tracked."
        },
        "nivelSucesso": {
          "type": "string",
          "description": "The level of success achieved."
        },
        "observacoes": {
          "type": "string",
          "description": "Optional observations made by the professor."
        },
        "authorUid": {
          "type": "string",
          "description": "The UID of the professor who created the record."
        }
      },
      "required": ["dataHora", "nomeAluno", "habilidadeAlvo", "nivelSucesso", "authorUid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/registros/{registroId}": {
      "schema": {
        "$ref": "#/entities/Registro"
      },
      "description": "Stores observation records for students."
    }
  }
}
